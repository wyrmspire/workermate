# === WorkerMate Environment Variables ===

# GEMINI_API_KEY: Required for Gemini AI vision model calls via Genkit.
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# NEXT_PUBLIC_MOCK_MODE: Set to true to bypass Gemini calls and return mock fixtures
NEXT_PUBLIC_MOCK_MODE=true
